{
  "name": "reduce-configs",
  "version": "2.0.0",
  "repository": "https://github.com/rstackjs/reduce-configs",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "pnpm run build",
    "test": "rstest",
    "bump": "npx bumpp"
  },
  "devDependencies": {
    "@rslib/core": "^0.21.5",
    "@rslint/core": "^0.5.3",
    "@rstest/core": "0.10.2",
    "@types/node": "^24.12.4",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.3.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
